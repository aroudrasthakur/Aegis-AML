APP_ENV=development
API_PORT=8000
FRONTEND_PORT=5173

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Model paths default to the repository ``models/`` directory (absolute paths resolved in app.config).
# From ``backend/``, that is ``../models/``. Uncomment only to override:
# MODEL_DIR=
# BEHAVIORAL_MODEL_PATH=
# BEHAVIORAL_AE_PATH=
# GRAPH_MODEL_PATH=
# ENTITY_MODEL_PATH=
# TEMPORAL_MODEL_PATH=
# OFFRAMP_MODEL_PATH=
# META_MODEL_PATH=
# THRESHOLD_POLICY_PATH=

FALLBACK_RISK_THRESHOLD=0.75
NETWORK_HOPS=3

# ML: set true to use GPU when available (CUDA for XGBoost+PyTorch; PyTorch may use Apple MPS if no CUDA)
ML_USE_GPU=false
